# Copy to .env and fill in. .env is gitignored.
# These same variables get set in the Vercel project for production.

# Supabase (service role key: server-side only, bypasses RLS)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Generation (M3)
ANTHROPIC_API_KEY=

# Publish flow (M4)
GITHUB_TOKEN=
GITHUB_REPO=               # "owner/name" of this repo on GitHub
GITHUB_BRANCH=main
SHEETS_WEBHOOK_URL=        # Apps Script web app URL (social-log-handler.gs)
SHEETS_WEBHOOK_SECRET=     # must match WEBHOOK_SECRET script property
VERIFY_BASE_URL=           # leave empty until DNS cutover; then https://realestateandloans.com

# Admin auth (M5)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=            # long random string for signing session cookies

# Cron + notifications + RAG (M6)
OPENAI_API_KEY=            # Whisper transcription (M5) + RAG embeddings (M6)
RESEND_API_KEY=            # reminder + review emails
TWILIO_ACCOUNT_SID=        # WhatsApp reminders
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=      # e.g. whatsapp:+14155238886 (Twilio sandbox/number)
GREGG_WHATSAPP_NUMBER=     # Gregg's number, pending from Simo; e.g. +19495551234
CRON_SECRET=               # Vercel sends "Authorization: Bearer <this>" to cron endpoints
# Cron schedule note (vercel.json is strict JSON, no comments):
#   publish runs at 6:02 AM Pacific. June 2026 = PDT (UTC-7) => 13:02 UTC.
#   When DST ends (Nov), Pacific = PST (UTC-8) => change schedules to 14:00/14:02 UTC.
# GOOGLE_CLIENT_ID=        (M5: admin OAuth)
# GOOGLE_CLIENT_SECRET=    (M5: admin OAuth)
# SESSION_SECRET=          (M5: signed session cookie)
# RESEND_API_KEY=          (M6: reminder + review emails)
# TWILIO_ACCOUNT_SID=      (M6: WhatsApp reminders)
# TWILIO_AUTH_TOKEN=       (M6: WhatsApp reminders)
# GREGG_WHATSAPP_NUMBER=   (M6: pending from Simo)
